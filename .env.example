# === Port-Konfiguration (pro Instanz anpassen) ===
APP_PORT=80              # Nginx (Production) — einziger extern exponierter Port
BACKEND_PORT=4000        # Backend API
FRONTEND_PORT=3000       # Frontend Dev-Server
DB_PORT=5432             # PostgreSQL (nur Dev — in Prod intern)

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=appdb

# Backend
DATABASE_URL=postgresql://app:secret@localhost:5432/appdb
CORS_ORIGIN=http://localhost:3000

# Frontend
BACKEND_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# Microsoft Entra ID (Azure AD) — für SSO
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Redis (optional — Cache deaktiviert wenn leer)
REDIS_URL=

# Sentry (optional — Error Tracking deaktiviert wenn leer)
SENTRY_DSN=

# Node
NODE_ENV=development
